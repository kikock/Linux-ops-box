# 数据库管理脚本配置文件
# 备份根目录（默认为脚本所在目录下的 backups/，可自定义绝对路径）
# 实际存储结构: $BACKUP_DIR/<连接别名>/<年份>/db_backup_<库名>_<时间>.sql.gz
# 示例: ./backups/生产MySQL/2025/db_backup_tk_user_20250427_020000.sql.gz
# BACKUP_DIR=/data/db_backups

# 最大保留备份数量（超出后自动删除最旧的）
MAX_BACKUPS=10

# 数据库连接配置文件路径（JSON格式）
DB_CONFIG_FILE=$(dirname "$0")/db_connections.json

# 默认备份压缩格式: gzip | none
BACKUP_COMPRESS=gzip

# 备份文件名前缀
BACKUP_PREFIX=db_backup
